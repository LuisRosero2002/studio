
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      if (!isSignedIn()) {
        return false;
      }
      let userRole = getUserData().role;
      return userRole == 'Admin' || userRole == 'Administrador comercial';
    }

    function isAssignedToLead(leadId) {
      let leadData = get(/databases/$(database)/documents/leads/$(leadId)).data;
      return isOwner(leadData.assignedToId);
    }
    
    function isAssignedToLeadOrManager(leadId) {
      return isSignedIn() && (isAssignedToLead(leadId) || isManager());
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Any signed-in user can see other users' basic info (for assign-to dropdowns)
      allow list, get: if isSignedIn();
      // Only the user themselves can create or update their own profile.
      allow create, update: if isOwner(userId);
      // Nobody can delete user profiles to maintain data integrity.
      allow delete: if false;
    }

    match /priceItems/{itemId} {
      // Any signed-in user can read the price list to create quotes.
      allow get, list: if isSignedIn();
      // Only managers can change the price list.
      allow create, update, delete: if isManager();
    }

    match /leads/{leadId} {
      // A user can read a lead if they are assigned to it or if they are a manager.
      // All managers can list all leads.
      allow get: if isAssignedToLeadOrManager(leadId);
      allow list: if isManager();
      // Only managers can create and delete leads.
      allow create, delete: if isManager();
      // Only the assigned user or a manager can update a lead.
      allow update: if isAssignedToLeadOrManager(leadId);
    }

    match /quotes/{quoteId} {
      // Access to a quote is determined by access to the parent lead.
      allow get, list, create, update, delete: if isAssignedToLeadOrManager(request.resource.data.leadId);
    }

    match /activities/{activityId} {
       // Access to an activity is determined by access to the parent lead.
      allow get, list, create, update, delete: if isAssignedToLeadOrManager(request.resource.data.leadId);
    }
  }
}
