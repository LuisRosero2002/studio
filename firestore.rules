rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(docData) {
      return request.auth.uid == docData.ownerId;
    }
    
    function isAssigned(docData) {
      return request.auth.uid == docData.assignedToId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isManager() {
      return getRole() in ['Admin', 'Administrador comercial'];
    }

    // Rules for collections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    match /priceItems/{itemId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isManager();
    }

    match /leads/{leadId} {
      allow read, list: if isManager() || isAssigned(get(/databases/$(database)/documents/leads/$(leadId)).data);
      allow create: if isManager() || isSignedIn();
      allow update, delete: if isManager() || isAssigned(get(/databases/$(database)/documents/leads/$(leadId)).data);
    }

    match /quotes/{quoteId} {
      allow read: if isManager() || isOwner(get(/databases/$(database)/documents/quotes/$(quoteId)).data);
      allow create: if isSignedIn();
      allow update, delete: if isManager() || isOwner(get(/databases/$(database)/documents/quotes/$(quoteId)).data);
    }
    
    match /activities/{activityId} {
      allow read: if isSignedIn(); // More specific rules can be added if needed
      allow create: if isSignedIn();
      allow update, delete: if isOwner(get(/databases/$(database)/documents/activities/$(activityId)).data);
    }
  }
}
