rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isManager() {
      // Use exists() to prevent errors if the user document doesn't exist yet.
      let userDocExists = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      if (!userDocExists) {
        return false;
      }
      // Roles are stored in the user's profile document.
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSignedIn() && (userRole == 'Admin' || userRole == 'Administrador comercial');
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    // Users can read/update their own profile. 
    // Listing users is allowed for any signed-in user to populate dropdowns.
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false; 
    }

    // Price Items can be listed and read by any signed-in user, as they are needed
    // for creating quotes. Only managers can create/modify them.
    match /priceItems/{itemId} {
      allow list, get: if isSignedIn();
      allow create, update, delete: if isManager();
    }

    // Leads can be accessed only by their assigned advisor or a manager.
    // Only managers can list all leads.
    match /leads/{leadId} {
      allow get: if isSignedIn() && (isOwner(resource.data.assignedToId) || isManager());
      allow list: if isManager();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(resource.data.assignedToId) || isManager());
      allow delete: if isManager();
    }
    
    // Activities access is derived from the parent lead.
    // The user must be the assigned advisor for the lead or a manager.
    match /activities/{activityId} {
      function isAllowedToAccessLead(leadId) {
        let leadDoc = get(/databases/$(database)/documents/leads/$(leadId));
        return isOwner(leadDoc.data.assignedToId) || isManager();
      }
      
      allow get, update, delete: if isSignedIn() && isAllowedToAccessLead(resource.data.leadId);
      allow list: if isManager();
      allow create: if isSignedIn() && isAllowedToAccessLead(request.resource.data.leadId);
    }

    // Quotes access is derived from the parent lead.
    // The user must be the assigned advisor for the lead or a manager.
    match /quotes/{quoteId} {
       function isAllowedToAccessLead(leadId) {
        let leadDoc = get(/databases/$(database)/documents/leads/$(leadId));
        return isOwner(leadDoc.data.assignedToId) || isManager();
      }

       allow get, update, delete: if isSignedIn() && isAllowedToAccessLead(resource.data.leadId);
       allow list: if isManager();
       allow create: if isSignedIn() && isAllowedToAccessLead(request.resource.data.leadId);
    }
  }
}
