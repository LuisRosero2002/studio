/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model, often referred to as a "data silo" architecture. 
 * All user-generated data, including leads and their related activities, is stored in subcollections under that user's 
 * unique ID. This ensures that users can only access data they explicitly own, providing strong security and privacy by default.
 *
 * Data Structure: The data is organized hierarchically starting with the /users/{userId} path. Each user's data,
 * such as leads (/users/{userId}/leads/{leadId}), activities, and quotes, is nested underneath their profile document.
 * This structure leverages path-based security, making authorization checks simple, performant, and easy to reason about.
 *
 * Key Security Decisions:
 * - Strict Ownership: All operations (read, write, delete) are restricted to the owner of the data, determined by the {userId} in the document path.
 * - No Public Data: There are no publicly readable collections. A user must be authenticated and be the designated owner to access any resource.
 * - Path-Based Security: Authorization relies on the document's path rather than its internal data, which avoids costly `get()` calls in rules.
 *
 * Denormalization for Authorization: This ruleset's strength comes from its structure. By nesting all of a user's content under
 * a path like `/users/{userId}/...`, ownership is implicitly defined. This avoids the need to add an `ownerId` field to every
 * single document and then check it. The path *is* the authorization check.
 *
 * Structural Segregation: The entire data model is built on this principle. All data is segregated into private user silos
 * under the top-level `/users` collection. This prevents any possibility of private data leaking into public queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth and validation
    // ==========================================

    /**
     * Verifies that the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies that the requesting user's UID matches the userId from the path.
     * This is the primary ownership check.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies ownership for an existing document. Used for update and delete.
     * Combines ownership check with a check that the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates that the UserProfile being created has an 'id' field
     * that matches the document's ID ({userId}), ensuring relational integrity.
     */
    function isValidUserProfileCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of the UserProfile's 'id' field during updates.
     */
    function isImmutableUserProfileId() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates that the Lead being created is correctly assigned to the user
     * in whose subcollection it is being placed.
     */
    function isValidLeadCreate(userId) {
      return request.resource.data.assignedToId == userId;
    }

    /**
     * Enforces immutability of the Lead's 'assignedTo' field during updates,
     * preventing a lead from being reassigned by changing the data.
     */
    function isImmutableLeadAssignment() {
      return request.resource.data.assignedToId == resource.data.assignedToId;
    }

    /**
     * Validates that the Activity's 'leadId' matches the parent document's
     * ID ({leadId}), ensuring the activity is linked to the correct lead.
     */
    function isValidActivityCreate(leadId) {
      return request.resource.data.leadId == leadId;
    }

    /**
     * Enforces immutability of the Activity's 'leadId' during updates.
     */
    function isImmutableActivityLeadLink() {
      return request.resource.data.leadId == resource.data.leadId;
    }

    /**
     * Validates that the Quote's 'leadId' matches the parent document's
     * ID ({leadId}), ensuring the quote is linked to the correct lead.
     */
    function isValidQuoteCreate(leadId) {
      return request.resource.data.leadId == leadId;
    }

    /**
     * Enforces immutability of the Quote's 'leadId' during updates.
     */
    function isImmutableQuoteLeadLink() {
      return request.resource.data.leadId == resource.data.leadId;
    }


    // Collection Rules
    // ==========================================

    /**
     * @description A user's own profile document and all their nested data.
     * @path /users/{userId}
     * @allow A user can do anything (get, list, create, update, delete) within their own document and subcollections.
     * @deny Any user trying to access another user's data tree.
     * @principle Restricts all access to a user's own data silo.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}