rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isManager() {
      // Use exists() to prevent errors if the user document doesn't exist yet.
      let userDocExists = exists(/databases/$(database)/documents/users/$(request.auth.uid));
      if (!userDocExists) {
        return false;
      }
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSignedIn() && (userRole == 'Sales Director' || userRole == 'Administrator' || userRole == 'Admin');
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    // Users can read/update their own profile. Managers can read any profile.
    // Listing all users is allowed for any signed-in user to populate dropdowns.
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false; 
    }

    // Price Items can be listed and read by any signed-in user, as they are needed
    // for creating quotes. Only managers or owners can modify them.
    match /priceItems/{itemId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isManager() || isOwner(resource.data.ownerId);
    }

    // Leads can be accessed only by their assigned advisor or a manager.
    // Only managers can list all leads.
    match /leads/{leadId} {
      allow get: if isSignedIn() && (isOwner(resource.data.assignedToId) || isManager());
      allow list: if isManager();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(resource.data.assignedToId) || isManager());
      allow delete: if isManager();
    }
    
    // Activities access is derived from the parent lead.
    // The user must be the assigned advisor for the lead or a manager.
    match /activities/{activityId} {
      function isAllowed() {
        let leadId = request.resource.data.leadId;
        let leadData = get(/databases/$(database)/documents/leads/$(leadId)).data;
        return isOwner(leadData.assignedToId) || isManager();
      }
      
      allow get: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.assignedToId) || isManager());
      allow list: if isManager();
      allow create: if isSignedIn() && isAllowed();
      allow update, delete: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.assignedToId) || isManager());
    }

    // Quotes access is derived from the parent lead.
    // The user must be the assigned advisor for the lead or a manager.
    match /quotes/{quoteId} {
        function isAllowed() {
            let leadId = request.resource.data.leadId;
            let leadData = get(/databases/$(database)/documents/leads/$(leadId)).data;
            return isOwner(leadData.assignedToId) || isManager();
        }

       allow get: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.assignedToId) || isManager());
       allow list: if isManager();
       allow create: if isSignedIn() && isAllowed();
       allow update, delete: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.assignedToId) || isManager());
    }
  }
}
